rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.sku is string && data.sku.size() <= 50 &&
             data.category is string &&
             data.createdAt is string &&
             data.keys().hasAll(['name', 'price', 'sku', 'category', 'createdAt']);
    }

    function isValidOrder(data) {
      return data.customerId == request.auth.uid &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.keys().hasAll(['customerId', 'total', 'status', 'createdAt', 'items']);
    }

    function isValidCustomer(data) {
      return data.email == request.auth.token.email &&
             data.loyaltyPoints is number &&
             data.tier in ['Silver', 'Gold', 'Platinum'] &&
             data.keys().hasAll(['name', 'email', 'loyaltyPoints', 'tier', 'orderCount', 'totalSpent', 'createdAt']);
    }

    function isValidJournalPost(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.author is string &&
             data.status in ['draft', 'published'] &&
             data.keys().hasAll(['title', 'author', 'content', 'status', 'publishDate']);
    }

    // --- Collections ---

    match /products/{productId} {
      allow read: if true; // Public catalogs
      allow write: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(orderId) && isValidOrder(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidOrder(incoming()) && incoming().updatedAt == request.time;
      allow delete: if false; 
    }

    match /customers/{customerId} {
      allow get: if isSignedIn() && (customerId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isEmailVerified() && customerId == request.auth.uid && isValidCustomer(incoming());
      allow update: if isSignedIn() && customerId == request.auth.uid && (
        // Action: Profile Update (Name Only)
        incoming().diff(existing()).affectedKeys().hasOnly(['name']) ||
        isAdmin()
      ) && incoming().loyaltyPoints == existing().loyaltyPoints && incoming().tier == existing().tier;
    }

    match /journal/{postId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin() && isValidId(postId) && isValidJournalPost(incoming());
    }

    match /quizResults/{resultId} {
      allow get, list: if isAdmin();
      allow create: if isValidId(resultId) && 
                    incoming().keys().hasAll(['recommendedProductIds', 'createdAt']) &&
                    incoming().recommendedProductIds.size() > 0;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console or super-admin
    }
  }
}
